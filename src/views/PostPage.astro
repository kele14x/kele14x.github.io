---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { BlogPost } from '../lib/content';
import { getAlternateLocale, getSiteTitle, type Locale } from '../lib/i18n';
import { buildLayoutProps } from '../lib/layout';
import { getPostPath, getTagPath } from '../lib/paths';

interface Props {
	locale: Locale;
	post: BlogPost;
}

const { locale, post } = Astro.props;
const { copy, homeHref, postsHref, tagsHref, aboutHref, languageLabel, navLabels } = buildLayoutProps(locale);
const { Content } = await render(post);
const publishedAt = post.data.date.toLocaleDateString('en-CA');
const alternateLocale = getAlternateLocale(locale);
const languageHref = getPostPath(alternateLocale, post.data.slug);
const siteTitle = getSiteTitle();
---

<BaseLayout
	title={`${post.data.title} | ${siteTitle}`}
	description={post.data.description ?? post.data.title}
	locale={locale}
	homeHref={homeHref}
	postsHref={postsHref}
	tagsHref={tagsHref}
	aboutHref={aboutHref}
	languageHref={languageHref}
	languageLabel={languageLabel}
	navLabels={navLabels}
>
	<article class="article">
		<header class="article-header">
			<p class="meta">{publishedAt}</p>
			<h1>{post.data.title}</h1>
			{post.data.tags && post.data.tags.length > 0 && (
				<ul class="tag-list">
					{post.data.tags.map((tag) => (
						<li><a class="tag" href={getTagPath(locale, tag)}>{tag}</a></li>
					))}
				</ul>
			)}
		</header>
		<Content />
	</article>
</BaseLayout>
