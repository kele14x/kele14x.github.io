---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPageBySlug, type PageEntry } from '../lib/content';
import { getAlternateLocale, type Locale } from '../lib/i18n';
import { buildLayoutProps } from '../lib/layout';
import { getAboutPath } from '../lib/paths';

interface Props {
	locale: Locale;
	page: PageEntry;
}

const { locale, page } = Astro.props;
const { copy, homeHref, postsHref, tagsHref, aboutHref, languageLabel, navLabels } = buildLayoutProps(locale);
const { Content } = await render(page);
const alternateLocale = getAlternateLocale(locale);
const alternatePage = await getPageBySlug(alternateLocale, page.data.slug);
const languageHref = alternatePage ? getAboutPath(alternateLocale) : getAboutPath(locale);
---

<BaseLayout
	title={page.data.title}
	description={page.data.description}
	locale={locale}
	homeHref={homeHref}
	postsHref={postsHref}
	tagsHref={tagsHref}
	aboutHref={aboutHref}
	languageHref={languageHref}
	languageLabel={languageLabel}
	navLabels={navLabels}
>
	<article class="article">
		<header class="article-header">
			<h1>{page.data.title}</h1>
		</header>
		<Content />
	</article>
</BaseLayout>
