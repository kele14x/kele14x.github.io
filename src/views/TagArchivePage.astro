---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostsByLocale } from '../lib/content';
import { getAlternateLocale, type Locale } from '../lib/i18n';
import { buildLayoutProps } from '../lib/layout';
import { getPostPath, getTagPath, getTagsIndexPath } from '../lib/paths';
import { hasTagPosts } from '../lib/tags';

interface Props {
	locale: Locale;
	tag: string;
}

const { locale, tag } = Astro.props;

if (!tag) {
	throw new Error('Missing tag parameter.');
}

const { copy, homeHref, postsHref, tagsHref, aboutHref, languageLabel, navLabels } = buildLayoutProps(locale);
const posts = (await getPostsByLocale(locale)).filter((post) =>
	(post.data.tags ?? []).some((item) => item.toLowerCase() === tag),
);
const alternateLocale = getAlternateLocale(locale);
const languageHref = (await hasTagPosts(tag, alternateLocale))
	? getTagPath(alternateLocale, tag)
	: getTagsIndexPath(alternateLocale);
---

<BaseLayout
	title={copy.tagArchiveTitle(tag)}
	description={copy.tagArchiveDescription(tag)}
	locale={locale}
	homeHref={homeHref}
	postsHref={postsHref}
	tagsHref={tagsHref}
	aboutHref={aboutHref}
	languageHref={languageHref}
	languageLabel={languageLabel}
	navLabels={navLabels}
>
	<section>
		<ul class="post-list">
			{posts.map((post) => (
				<li>
					<article class="article-card">
						<p class="meta">{post.data.date.toLocaleDateString('en-CA')}</p>
						<h2><a href={getPostPath(locale, post.data.slug)}>{post.data.title}</a></h2>
						{post.data.tags && post.data.tags.length > 0 && (
							<ul class="tag-list">
								{post.data.tags.map((postTag) => (
									<li><a class="tag" href={getTagPath(locale, postTag)}>{postTag}</a></li>
								))}
							</ul>
						)}
					</article>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>
