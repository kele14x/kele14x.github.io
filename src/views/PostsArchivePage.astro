---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostsByLocale } from '../lib/content';
import { getAlternateLocale, type Locale } from '../lib/i18n';
import { buildLayoutProps } from '../lib/layout';
import { getPostPath, getPostsIndexPath, getTagPath } from '../lib/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const { copy, homeHref, postsHref, tagsHref, aboutHref, languageLabel, navLabels } = buildLayoutProps(locale);
const posts = await getPostsByLocale(locale);
const alternateLocale = getAlternateLocale(locale);
const languageHref = getPostsIndexPath(alternateLocale);
---

<BaseLayout
	title={copy.allPostsTitle}
	description={copy.allPostsDescription}
	locale={locale}
	homeHref={homeHref}
	postsHref={postsHref}
	tagsHref={tagsHref}
	aboutHref={aboutHref}
	languageHref={languageHref}
	languageLabel={languageLabel}
	navLabels={navLabels}
>
	<section>
		<ul class="post-list">
			{posts.map((post) => (
				<li>
					<article class="article-card">
						<p class="meta">{post.data.date.toLocaleDateString('en-CA')}</p>
						<h2><a href={getPostPath(locale, post.data.slug)}>{post.data.title}</a></h2>
						{post.data.tags && post.data.tags.length > 0 && (
							<ul class="tag-list">
								{post.data.tags.map((tag) => (
									<li><a class="tag" href={getTagPath(locale, tag)}>{tag}</a></li>
								))}
							</ul>
						)}
					</article>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>
