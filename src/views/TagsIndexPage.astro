---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostsByLocale } from '../lib/content';
import { getAlternateLocale, getTagsTitle, type Locale } from '../lib/i18n';
import { buildLayoutProps } from '../lib/layout';
import { getTagPath, getTagsIndexPath } from '../lib/paths';
import { buildTagMap } from '../lib/tags';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const { copy, homeHref, postsHref, tagsHref, aboutHref, languageLabel, navLabels } = buildLayoutProps(locale);
const tags = buildTagMap(await getPostsByLocale(locale));
const alternateLocale = getAlternateLocale(locale);
const languageHref = getTagsIndexPath(alternateLocale);
const tagsTitle = getTagsTitle(locale);
---

<BaseLayout
	title={tagsTitle}
	description={copy.tagsDescription}
	locale={locale}
	homeHref={homeHref}
	postsHref={postsHref}
	tagsHref={tagsHref}
	aboutHref={aboutHref}
	languageHref={languageHref}
	languageLabel={languageLabel}
	navLabels={navLabels}
>
	<section>
		<ul class="post-list">
			{tags.map((tag) => (
				<li>
					<article class="article-card">
						<h2><a href={getTagPath(locale, tag.slug)}>#{tag.label}</a></h2>
						<p class="meta">{copy.postsLabel(tag.count)}</p>
					</article>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>
