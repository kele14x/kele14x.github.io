---
import 'katex/dist/katex.min.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Kele's Blog",
	description = 'Notes on FPGA, communication systems, and engineering topics.',
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="shell header-inner">
				<a class="brand" href="/">Kele's Blog</a>
				<nav>
					<a href="/posts/">Posts</a>
					<a href="/tags/">Tags</a>
					<a href="/about/">About</a>
				</nav>
			</div>
		</header>
		<main class="shell content">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f5f3ee;
		--surface: #fffdf8;
		--surface-strong: #ffffff;
		--text: #1c1917;
		--muted: #57534e;
		--border: #d6d3d1;
		--accent: #0f766e;
		--accent-soft: #ccfbf1;
		--code: #292524;
		--code-bg: #f1f5f9;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background-color: var(--bg);
		background-image: linear-gradient(180deg, #f8fafc 0%, var(--bg) 30%, #f7f4ed 100%);
		background-repeat: no-repeat;
		background-size: 100% 100vh;
		color: var(--text);
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.shell {
		width: min(100% - 2rem, 52rem);
		margin: 0 auto;
	}

	.site-header {
		border-bottom: 1px solid var(--border);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.75rem 0;
	}

	.brand {
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	nav {
		display: flex;
		gap: 1rem;
		font-size: 0.95rem;
	}

	.content {
		padding: 2.5rem 0 4rem;
	}

	.content > :first-child,
	.content > section:first-child > :first-child,
	.content > article:first-child > :first-child {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(2.2rem, 6vw, 3.6rem);
		margin: 0 0 1rem;
	}

	h2 {
		font-size: clamp(1.5rem, 4vw, 2rem);
		margin-top: 2.5rem;
	}

	p,
	li,
	blockquote {
		font-size: 1.02rem;
		line-height: 1.75;
	}

	img {
		max-width: 100%;
		height: auto;
		border-radius: 0.75rem;
	}

	pre {
		overflow-x: auto;
		padding: 1rem;
		border-radius: 0.75rem;
		background: var(--code);
		color: #fafaf9;
	}

	code {
		font-family: "SFMono-Regular", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.92em;
	}

	p code,
	li code,
	td code,
	th code {
		background: var(--code-bg);
		padding: 0.15rem 0.35rem;
		border-radius: 0.35rem;
	}

	blockquote {
		margin: 1.5rem 0;
		padding: 0.25rem 0 0.25rem 1rem;
		border-left: 3px solid var(--border);
		color: var(--muted);
	}

	table {
		display: block;
		overflow-x: auto;
		border-collapse: collapse;
		max-width: 100%;
	}

	th,
	td {
		padding: 0.65rem 0.8rem;
		border: 1px solid var(--border);
		text-align: left;
	}

	hr {
		border: 0;
		border-top: 1px solid var(--border);
		margin: 2rem 0;
	}

	.article-card,
	.panel {
		background: color-mix(in srgb, var(--surface-strong) 88%, transparent);
		border: 1px solid color-mix(in srgb, var(--border) 85%, transparent);
		border-radius: 1rem;
		padding: 1.2rem;
		box-shadow: 0 10px 30px rgba(28, 25, 23, 0.04);
	}

	.meta,
	.muted {
		color: var(--muted);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
	}

	.tag {
		display: inline-flex;
		padding: 0.3rem 0.7rem;
		border-radius: 999px;
		background: var(--accent-soft);
		color: #134e4a;
		font-size: 0.9rem;
	}

	.hero {
		display: grid;
		gap: 1.5rem;
		align-items: center;
		margin-bottom: 2rem;
	}

	.hero img {
		width: 100%;
		max-width: 28rem;
		justify-self: center;
	}

	.post-list {
		display: grid;
		gap: 1rem;
		padding: 0;
		list-style: none;
	}

	.post-list li {
		margin: 0;
	}

	.pagination {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.5rem;
	}

	.page-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.5rem;
		padding: 0.45rem 0.8rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface-strong) 88%, transparent);
		color: var(--text);
	}

	.page-link.is-current {
		background: var(--accent);
		border-color: var(--accent);
		color: #f8fafc;
	}

	.article {
		background: color-mix(in srgb, var(--surface-strong) 90%, transparent);
		border: 1px solid color-mix(in srgb, var(--border) 85%, transparent);
		border-radius: 1.25rem;
		padding: clamp(1.25rem, 4vw, 2rem);
		box-shadow: 0 16px 40px rgba(28, 25, 23, 0.05);
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.article-header p {
		margin: 0.5rem 0 0;
	}

	@media (min-width: 48rem) {
		.hero {
			grid-template-columns: 1.15fr 0.85fr;
		}
	}
</style>
