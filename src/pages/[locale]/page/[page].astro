---
import HomePage from '../../../views/HomePage.astro';
import { PAGE_SIZE, getPostsByLocale } from '../../../lib/content';
import { LOCALES, isLocale } from '../../../lib/i18n';

export async function getStaticPaths() {
	const localePages = await Promise.all(
		LOCALES.map(async (locale) => {
			const posts = await getPostsByLocale(locale);
			const pageCount = Math.ceil(posts.length / PAGE_SIZE);

			return Array.from({ length: Math.max(pageCount - 1, 0) }, (_, index) => ({
				params: {
					locale,
					page: String(index + 2),
				},
			}));
		}),
	);

	return localePages.flat();
}

const { locale: localeParam, page } = Astro.params;

if (!isLocale(localeParam)) {
	throw new Error(`Unsupported locale: ${localeParam}`);
}

const locale = localeParam;
const currentPage = Number(page);
---

<HomePage locale={locale} currentPage={currentPage} />
