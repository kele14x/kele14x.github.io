---
import PostPage from '../../templates/PostPage.astro';
import { getPostsByLocale } from '../../lib/blog';

export async function getStaticPaths() {
	const posts = await getPostsByLocale('en');

	return posts.map((post) => ({
		params: {
			slug: post.data.slug,
		},
		props: { post },
	}));
}

const { post } = Astro.props;
---

<PostPage locale="en" post={post} />
