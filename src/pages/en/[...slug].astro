---
import PostPage from '../../templates/PostPage.astro';
import { getPostsByLocale } from '../../lib/blog';

export async function getStaticPaths() {
	const [englishPosts, chinesePosts] = await Promise.all([
		getPostsByLocale('en'),
		getPostsByLocale('zh'),
	]);
	const postsBySlug = new Map(chinesePosts.map((post) => [post.data.slug, post]));

	for (const post of englishPosts) {
		postsBySlug.set(post.data.slug, post);
	}

	return [...postsBySlug.values()].map((post) => ({
		params: {
			slug: post.data.slug,
		},
		props: { post },
	}));
}

const { post } = Astro.props;
---

<PostPage locale="en" post={post} />
