---
import TagArchivePage from '../../../templates/TagArchivePage.astro';
import { getPostsByLocale } from '../../../lib/blog';

export async function getStaticPaths() {
	const posts = await getPostsByLocale('zh');
	const tags = new Set(
		posts.flatMap((post) => (post.data.tags ?? []).map((tag) => tag.toLowerCase())),
	);

	return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
---

<TagArchivePage locale="zh" tag={tag!} />
