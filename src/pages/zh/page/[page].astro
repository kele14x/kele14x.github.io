---
import HomePage from '../../../templates/HomePage.astro';
import { PAGE_SIZE, getPostsByLocale } from '../../../lib/blog';

export async function getStaticPaths() {
	const posts = await getPostsByLocale('zh');
	const pageCount = Math.ceil(posts.length / PAGE_SIZE);

	return Array.from({ length: Math.max(pageCount - 1, 0) }, (_, index) => ({
		params: {
			page: String(index + 2),
		},
	}));
}

const currentPage = Number(Astro.params.page);
---

<HomePage locale="zh" currentPage={currentPage} />
